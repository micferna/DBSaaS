# DBSaaS Platform — Configuration
#
# 1. Generate secrets:  ./scripts/init-secrets.sh
# 2. Local dev:         source scripts/load-secrets.sh
# 3. Docker:            docker compose up -d

# Platform (non-sensitive)
PLATFORM_DOMAIN=localhost
PORT_RANGE_START=10000
PORT_RANGE_END=60000
MAX_DATABASES_PER_USER=5
REGISTRATION_ENABLED=true

# Optional: restrict CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3003
